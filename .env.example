# Gemini AI API key — required for the AI Boardroom Advisor chatbot.
# In Vite, env variables must be prefixed with VITE_ to be accessible in the browser.
# Step 1: Copy this file to .env.local (never commit .env.local to git)
# Step 2: Replace the placeholder below with your actual Gemini API key
# Step 3: Run `npm run dev` — the chatbot will activate automatically
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# App URL (used for self-referential links if needed)
APP_URL="http://localhost:3000"
